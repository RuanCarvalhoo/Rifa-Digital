# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rifinha
# Alternativamente, use as variáveis abaixo (DATABASE_URL tem prioridade se definida):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=rifinha
